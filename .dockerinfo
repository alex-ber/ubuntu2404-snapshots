# ----------------------------------
# Git / CI (never in image)
# ----------------------------------
.git
.gitignore
.github

# ----------------------------------
# Python artifacts
# ----------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------------
# Environments (must NOT leak)
# ----------------------------------
.env
.env.*
.venv*
venv*
env/
ENV/
virtualenv/

# ----------------------------------
# Secrets (CRITICAL)
# ----------------------------------
.secrets/
credentials.json
*.pem

# ----------------------------------
# IDE / OS
# ----------------------------------
.idea/
*.kdev4
.vscode/
.DS_Store
*~
*.swp
*.swo

# ----------------------------------
# Build artifacts
# ----------------------------------
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz

# ----------------------------------
# Test artifacts
# ----------------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ----------------------------------
# Runtime / data
# ----------------------------------
*.log
*.sqlite
*.sqlite3
*.db
.ipynb_checkpoints/

# ----------------------------------
# Optional: exclude docs if not needed in image
# ----------------------------------
docs/

# ----------------------------------
# Keep Dockerfile
# ----------------------------------
!Dockerfile
