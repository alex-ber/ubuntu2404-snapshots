# ----------------------------------
# Python
# ----------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------------
# Packaging / build
# ----------------------------------
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz

# ----------------------------------
# Logs
# ----------------------------------
*.log

# ----------------------------------
# Environments (CRITICAL)
# ----------------------------------
.env
.env.*
.venv*
venv*
env/
ENV/
env.bak/
virtualenv/
node_modules/

# ----------------------------------
# Secrets (CRITICAL)
# ----------------------------------
.secrets/
credentials.json
*.pem
*.key

# ----------------------------------
# IDE / OS noise
# ----------------------------------
.idea/
.vscode/
*.kdev4
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# ----------------------------------
# Data artifacts
# ----------------------------------
*.pkl
*.bin
.ipynb_checkpoints/

# ----------------------------------
# Testing / tooling
# ----------------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ----------------------------------
# Local scratch
# ----------------------------------
prof/
scratch/

# ----------------------------------
# Allow scripts explicitly
# ----------------------------------
!*.bat
!*.sh


